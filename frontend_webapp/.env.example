# Backend API base (optional)
# If not set, the app defaults to: ${window.location.protocol}//${window.location.hostname}:3001
REACT_APP_BACKEND_URL=

# Supabase (required if enabling Supabase features/auth)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# Used for auth redirects / email templates
REACT_APP_SITE_URL=http://localhost:3000
